# Environment Configuration Example
# Copy this file to .env for local development or set these variables in your deployment environment

# Server Configuration
# Set to 'production' for deployment, 'development' for local dev
NODE_ENV=development
PORT=5000

# Database Configuration (Not required - frontend interface only)
# DATABASE_URL=postgresql://user:password@localhost:5432/manufacturing_crm

# Security Configuration
SESSION_SECRET=your-secure-session-secret-key-change-this-in-production

# CORS Configuration (Optional - comma-separated list for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Development/Production API URLs (if needed)
VITE_DEV_API_BASE_URL=http://localhost:5000
VITE_PROD_API_BASE_URL=https://your-production-domain.com
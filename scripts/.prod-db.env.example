# Copy to scripts/.prod-db.env and fill in. That file is gitignored — never commit it.
#
#   cp scripts/.prod-db.env.example scripts/.prod-db.env

# --- Production droplet (SSH) ---
PROD_HOST=          # droplet IP or hostname (the PROD_DROPLET_HOST GitHub secret)
PROD_USER=root
PROD_PASS=          # root password — QUOTE it if it has special chars, e.g. PROD_PASS='p@ss&word'
PROD_SSH_PORT=22

# --- Production DB (defaults match docker-compose.prod.yaml) ---
PROD_DB_USER=local
PROD_DB_NAME=backend
# PROD_DB_CONTAINER=    # leave blank to auto-detect the postgis container

# --- Local target (defaults match docker-compose.local.yml) ---
# LOCAL_DB_USER=local
# LOCAL_DB_NAME=backend
